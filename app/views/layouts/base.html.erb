<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title>Minecraft Server Compendium</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= stylesheet_pack_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>
  <body class="flex flex-col bg-gray-100">
    <div class="fixed inset-0 px-4 py-6 pointer-events-none sm:p-6 sm:items-start sm:justify-end">
      <div class="flex flex-col items-end justify-center">
        <% flash.each do |type, data| %>
          <%= render AlertComponent.new(type: type, data: data) %>
        <% end %>
      </div>
    </div>
    <%= content_for?(:body) ? yield(:body) : yield %>
  </body>
</html>
