<%= form_with model: server, local: true, class: 'flex flex-col space-y-4' do |form| %>
  <%= render 'shared/errors', record: server %>

  <%= hidden_field_tag :referrer, @referrer %>

  <div class="flex flex-col">
    <%= form.label :name, class: 'block text-sm font-medium leading-5 text-gray-700' %>
    <div class="relative mt-1 rounded-md shadow-sm">
      <%= form.text_field :name, class: 'block w-full pr-12 form-input pl-7 sm:text-sm sm:leading-5' %>
    </div>
  </div>

  <div class="flex flex-col">
    <%= form.label :description, class: 'block text-sm font-medium leading-5 text-gray-700' %>
    <div class="relative mt-1 rounded-md shadow-sm">
      <%= form.text_field :description, class: 'block w-full pr-12 form-input pl-7 sm:text-sm sm:leading-5' %>
    </div>
  </div>

  <div class="flex flex-col">
    <%= form.label :hostname, class: 'block text-sm font-medium leading-5 text-gray-700' %>
    <div class="relative mt-1 rounded-md shadow-sm">
      <%= form.text_field :hostname, class: 'block w-full pr-12 form-input pl-7 sm:text-sm sm:leading-5' %>
    </div>
  </div>

  <div class="flex flex-col">
    <%= form.label :port, class: 'block text-sm font-medium leading-5 text-gray-700' %>
    <div class="relative mt-1 rounded-md shadow-sm">
      <%= form.text_field :port, class: 'block w-full pr-12 form-input pl-7 sm:text-sm sm:leading-5' %>
    </div>
  </div>

  <div class="flex items-center justify-between">
    <%= form.submit class: 'px-4 py-2 text-green-100 bg-green-700 rounded-lg cursor-pointer form-submit hover:bg-green-800' %>
    <%= link_to 'Cancel', (@referrer_path || servers_path), class: 'px-4 py-2 text-gray-600 rounded-lg hover:text-gray-800' %>
  </div>
<% end %>
