<%= component :container do %>
  <div class="flex flex-col p-2 mb-4">
    <div class="flex justify-between h-12">
      <div class="text-lg font-medium"><%= @server.name %></div>
      <div class="self-end">
        <button class="px-6 py-2 border border-gray-300 rounded-md">Edit</button>
      </div>
    </div>

    <div class="flex space-x-10 text-gray-500 border-b border-gray-300">
      <button class="border-b-2 border-transparent hover:text-gray-800 hover:border-gray-800">Locations</button>
      <button class="border-b-2 border-transparent hover:text-gray-800 hover:border-gray-800">Server Details</button>
    </div>
  </div>

  <%= component :panel do %>
    <%# server details %>
    <div class="h-72"></div>
  <% end %>
<% end %>
