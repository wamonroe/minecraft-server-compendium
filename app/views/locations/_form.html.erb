<%= form_with model: location, local: true, class: 'flex flex-col space-y-4' do |form| %>
  <%= render 'shared/errors', record: location %>

  <%= form.hidden_field :server_id %>
  <%= hidden_field_tag :referrer, @referrer %>  

  <div class="flex flex-col">
    <%= form.label :name, class: 'block text-sm font-medium leading-5 text-gray-700' %>
    <div class="relative mt-1 rounded-md shadow-sm">
      <%= form.text_field :name, class: 'block w-full pr-12 form-input pl-7 sm:text-sm sm:leading-5' %>
    </div>
  </div>

  <div class="flex flex-col">
    <%= form.label :description, class: 'block text-sm font-medium leading-5 text-gray-700' %>
    <div class="relative mt-1 rounded-md shadow-sm">
      <%= form.text_field :description, class: 'block w-full pr-12 form-input pl-7 sm:text-sm sm:leading-5' %>
    </div>
  </div>

  <div class="flex flex-col">
    <%= form.label :dimension, class: 'block text-sm font-medium leading-5 text-gray-700' %>
    <div class="relative mt-1 rounded-md shadow-sm">
      <%= form.select :dimension, location.dimension_options, {}, { class: 'block w-full pr-12 form-select pl-7 sm:text-sm sm:leading-5' } %>
    </div>
  </div>

  <div class="flex flex-col">
    <h2 class="text-sm font-medium leading-5 text-gray-700">Coordinates</h2>
    <div class="flex p-5 mt-1 space-x-4 border border-gray-300 rounded-md shadow-sm">
      <div class="flex flex-col w-1/3">
        <%= form.label :x, class: 'block text-sm font-medium leading-5 text-gray-700' %>
        <div class="relative mt-1 rounded-md shadow-sm">
          <%= form.text_field :x, class: 'block w-full pr-12 form-input pl-7 sm:text-sm sm:leading-5' %>
        </div>
      </div>

      <div class="flex flex-col w-1/3">
        <%= form.label :y, class: 'block text-sm font-medium leading-5 text-gray-700' %>
        <div class="relative mt-1 rounded-md shadow-sm">
          <%= form.text_field :y, class: 'block w-full pr-12 form-input pl-7 sm:text-sm sm:leading-5' %>
        </div>
      </div>

      <div class="flex flex-col w-1/3">
        <%= form.label :z, class: 'block text-sm font-medium leading-5 text-gray-700' %>
        <div class="relative mt-1 rounded-md shadow-sm">
          <%= form.text_field :z, class: 'block w-full pr-12 form-input pl-7 sm:text-sm sm:leading-5' %>
        </div>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-between">
    <%= form.submit class: 'px-4 py-2 text-green-100 bg-green-700 rounded-lg cursor-pointer form-submit hover:bg-green-800' %>
    <%= link_to 'Cancel', (@referrer_path || server_path(location.server)), class: 'px-4 py-2 text-gray-600 rounded-lg hover:text-gray-800' %>
  </div>
<% end %>
