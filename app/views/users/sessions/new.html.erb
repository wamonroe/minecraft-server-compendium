<% content_for(:header) do %>
  <h1 class="mt-6 text-3xl font-extrabold leading-9 text-gray-900">Sign in to your account</h1>
  <% if devise_mapping.registerable? && controller_name != 'registrations' %>
    <div class="text-sm leading-5 text-gray-600">
      Or <%= link_to "sign up for a new account", new_user_registration_path, class: 'text-green-700 hover:text-green-800' %>
    </div>
  <% end %>
<% end %>

<%= form_for(resource, as: resource_name, url: user_session_path, html: { class: 'flex flex-col space-y-6' }) do |form| %>
  <div class="flex flex-col">
    <%= form.label :email, class: 'block text-sm font-medium leading-5 text-gray-700' %>
    <div class="relative mt-1 rounded-md shadow-sm">
      <%= form.email_field :email, autofocus: true, autocomplete: 'email', class: 'block w-full pr-12 form-input sm:text-sm sm:leading-5' %>
    </div>
  </div>

  <div class="flex flex-col">
    <%= form.label :password, class: 'block text-sm font-medium leading-5 text-gray-700' %>
    <div class="relative mt-1 rounded-md shadow-sm">
      <%= form.password_field :password, autocomplete: 'current-password', class: 'block w-full pr-12 form-input sm:text-sm sm:leading-5' %>
    </div>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="flex items-center">
      <%= form.check_box :remember_me, autocomplete: 'current-password', class: 'w-4 h-4 text-green-700 transition duration-150 ease-in-out form-checkbox' %>
      <%= form.label :remember_me, class: 'block ml-2 text-sm leading-5 text-gray-900' %>
    </div>
  <% end %>

  <div class="flex items-center justify-between">
    <%= form.submit "Log in", class: 'px-4 py-2 text-green-100 bg-green-700 rounded-lg cursor-pointer form-submit hover:bg-green-800' %>
    <div class="relative" data-controller="dropdown">
      <button class="relative z-10 block text-green-700 hover:text-green-800" data-action="dropdown#toggle">
        Need help?
      </button>
      <div class="absolute right-0 w-64 py-2 text-gray-800 bg-white border-2 border-gray-300 rounded-lg shadow-xl" data-target="dropdown.menu">
        <%= render "users/shared/links" %>
      </div>
    </div>
  </div>
<% end %>

<% if devise_mapping.omniauthable? %>
  <% resource_class.omniauth_providers.each do |provider| %>
    <%= link_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", user_omniauth_authorize_path(resource_name, provider) %><br />
  <% end %>
<% end %>
